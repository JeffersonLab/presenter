{
  "dockerComposeFile": "dev.yaml",
  "service": "dev",
  "workspaceFolder": "/home/dev/presenter",
  "runServices": [
    "dev",
    "oracle",
    "keycloak",
    "puppet",
    "resize"
  ],
  "remoteUser": "dev",
  "updateRemoteUserUID": false,
  "customizations": {
    "jetbrains": {
      "backend": "IntelliJ"
    },
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack","redhat.vscode-server-connector"]
    }
  }
}